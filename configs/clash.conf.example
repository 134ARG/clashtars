subscription:
  url: "https://example.invalid/subscription"
  timeout: "30s"
  user-agent: "clashtars/1.0"

mihomo:
  port: 7890
  socks-port: 7891
  redir-port: 7892
  allow-lan: true
  mode: rule
  log-level: silent
  external-controller: "0.0.0.0:9091"
  # Optional. Defaults to the ui/ directory beside this file.
  # external-ui: "/var/lib/clashtars/ui"
  secret: ""
